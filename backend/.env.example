# ─── COPY THIS FILE TO .env AND FILL IN YOUR KEYS ───────────────────────────
# DO NOT commit .env to git — it's in .gitignore

# Your OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Your GitHub Personal Access Token (needs repo scope)
# Get it at: https://github.com/settings/tokens → Generate new token (classic)
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# Your GitHub repo in format: username/repo-name
GITHUB_REPO=yourusername/chartai

# Your Polygon.io API key for real market data (free tier works)
# Get it at: https://polygon.io (free account)
POLYGON_API_KEY=YOUR_POLYGON_KEY_HERE

# Secret for signing JWT tokens — make this a long random string
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Port (Railway sets this automatically, leave as 3001 for local)
PORT=3001

# Database URL (Railway sets this automatically when you add PostgreSQL plugin)
# For local dev: install PostgreSQL and create a database called chartai
DATABASE_URL=postgresql://postgres:password@localhost:5432/chartai

# Redis URL (Railway sets this automatically when you add Redis plugin)
# For local dev: install Redis and leave as default
REDIS_URL=redis://localhost:6379

# Your app's public URL (Railway gives you this after first deploy)
APP_URL=https://your-app.railway.app
